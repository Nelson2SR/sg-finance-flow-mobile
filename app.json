{
  "expo": {
    "name": "VaultWise",
    "slug": "ai-finance-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aifinancetracker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aifinancetracker.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "VaultWise uses the camera so you can snap receipts and import statements with Magic Scan.",
        "NSPhotoLibraryUsageDescription": "VaultWise needs photo library access to import receipt images you've already saved.",
        "NSFaceIDUsageDescription": "Face ID unlocks your private finance data on this device.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": []
    },
    "android": {
      "package": "com.aifinancetracker.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
